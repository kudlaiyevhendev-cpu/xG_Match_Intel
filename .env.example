# Agent layer (LLM) — only needed when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# LLM provider: stub (default, offline/deterministic) | anthropic
LLM_PROVIDER=stub
# Default Claude model for the agent (Sonnet 5 balances agentic quality and cost)
LLM_MODEL=claude-sonnet-5

# football-data.org token (optional secondary data source, 10 req/min free tier)
FOOTBALL_DATA_TOKEN=

# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/xgintel
DB_USER=xgintel
DB_PASSWORD=xgintel

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
